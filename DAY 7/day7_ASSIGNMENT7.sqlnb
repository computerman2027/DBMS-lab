  - kind: 2
    value: "INSERT ALL\r

      INTO GRADE_39 VALUES (1, 0, 9999)\r

      INTO GRADE_39 VALUES (2, 10000, 19999)\r

      INTO GRADE_39 VALUES (3, 20000, 29999)\r

      INTO GRADE_39 VALUES (4, 30000, 39999)\r

      INTO GRADE_39 VALUES (5, 40000, 59999)\r

      SELECT * FROM DUAL;"
    languageId: oracle-sql
  - kind: 2
    value: SELECT * FROM EMP_39;
    languageId: oracle-sql
  - kind: 2
    value: SELECT * FROM GRADE_39
    languageId: oracle-sql
  - kind: 1
    value: A)
    languageId: markdown
  - kind: 2
    value: "SELECT ENAME FROM EMP_39\r

      WHERE SAL = (\r

      \    SELECT MAX(SAL) \r

      \    FROM EMP_39\r

      )"
    languageId: oracle-sql
  - kind: 1
    value: B)
    languageId: markdown
  - kind: 2
    value: "SELECT ENAME FROM EMP_39\r

      WHERE SAL = (\r

      \    SELECT MAX(SAL) \r

      \    FROM EMP_39\r

      \    WHERE JOB = 'SALESMAN'\r

      ) AND JOB = 'SALESMAN'"
    languageId: oracle-sql
  - kind: 1
    value: C)
    languageId: markdown
  - kind: 2
    value: "SELECT ENAME FROM EMP_39\r

      WHERE SAL = (\r

      \    SELECT MIN(SAL) \r

      \    FROM EMP_39\r

      \    WHERE JOB = 'CLERK'\r

      ) AND JOB = 'CLERK'"
    languageId: oracle-sql
  - kind: 1
    value: D)
    languageId: markdown
  - kind: 2
    value: "SELECT DEPT_NAME , AVG(SAL)\r

      FROM EMP_39\r

      GROUP BY DEPT_NAME"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT *\r

      FROM (\r

      \    SELECT DEPT_NAME, AVG(SAL) AS AVG_SAL\r

      \    FROM EMP_39\r

      \    GROUP BY DEPT_NAME\r

      \    ORDER BY AVG_SAL DESC\r

      )\r

      WHERE ROWNUM = 1;"
    languageId: oracle-sql
  - kind: 1
    value: E)
    languageId: markdown
  - kind: 2
    value: "SELECT * \r

      FROM EMP_39 \r

      WHERE SAL > (\r

      \    SELECT SAL \r

      \    FROM EMP_39\r

      \    WHERE ENAME = 'TURNER'\r

      )\r

      ORDER BY SAL DESC"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT * \r

      \    FROM EMP_39\r

      \    WHERE ENAME = 'TURNER'"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT ENAME \r

      FROM EMP_39 \r

      WHERE SAL > (\r

      \    SELECT SAL \r

      \    FROM EMP_39\r

      \    WHERE ENAME = 'TURNER'\r

      )\r

      ORDER BY SAL DESC"
    languageId: oracle-sql
  - kind: 1
    value: F)
    languageId: markdown
  - kind: 2
    value: "SELECT * FROM EMP_39 \r

      WHERE HIREDATE > (\r

      \    SELECT HIREDATE FROM EMP_39\r

      \    WHERE ENAME = 'ALLEN'\r

      )\r

      ORDER BY HIREDATE DESC"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT * FROM EMP_39\r

      \    WHERE ENAME = 'ALLEN'"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT ENAME FROM EMP_39 \r

      WHERE HIREDATE > (\r

      \    SELECT HIREDATE FROM EMP_39\r

      \    WHERE ENAME = 'ALLEN'\r

      )\r

      ORDER BY HIREDATE DESC"
    languageId: oracle-sql
  - kind: 1
    value: G)
    languageId: markdown
  - kind: 2
    value: "SELECT DEPT_NAME FROM EMP_39 \r

      WHERE ENAME = 'FORD'"
    languageId: oracle-sql
  - kind: 1
    value: H)
    languageId: markdown
  - kind: 2
    value: "SELECT DEPT_NAME , SUM(SAL) AS TOTAL_SALARY\r

      FROM EMP_39\r

      GROUP BY DEPT_NAME \r

      ORDER BY TOTAL_SALARY DESC"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT *\r

      FROM (\r

      \    SELECT DEPT_NAME, SUM(SAL) AS TOTAL_SALARY\r

      \    FROM EMP_39\r

      \    GROUP BY DEPT_NAME\r

      \    ORDER BY TOTAL_SALARY DESC\r

      )\r

      WHERE ROWNUM = 1;"
    languageId: oracle-sql
  - kind: 1
    value: I)
    languageId: markdown
  - kind: 2
    value: "SELECT CITY FROM EMP_39 \r

      WHERE ENAME = 'SMITH'"
    languageId: oracle-sql
  - kind: 1
    value: J)
    languageId: markdown
  - kind: 2
    value: "SELECT DISTINCT CITY FROM EMP_39 \r

      WHERE JOB = 'MANAGER'"
    languageId: oracle-sql
  - kind: 1
    value: K)
    languageId: markdown
  - kind: 2
    value: "SELECT GRADE\r

      FROM GRADE_39\r

      WHERE (SELECT SAL \r

      \       FROM EMP_39 \r

      \       WHERE ENAME = 'MARTIN')\r

      BETWEEN MINSAL AND MAXSAL;"
    languageId: oracle-sql
  - kind: 1
    value: L)
    languageId: markdown
  - kind: 2
    value: "SELECT * FROM EMP_39 \r

      WHERE SAL > (\r

      \    SELECT MAX(SAL) \r

      \    FROM EMP_39 \r

      \    WHERE CITY = 'DALLAS'\r

      )\r

      ORDER BY SAL DESC"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT *\r

      \    FROM EMP_39 \r

      \    WHERE CITY = 'DALLAS'"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT MAX(SAL) \r

      \    FROM EMP_39 \r

      \    WHERE CITY = 'DALLAS'"
    languageId: oracle-sql
  - kind: 1
    value: M)
    languageId: markdown
  - kind: 2
    value: "SELECT DEPT_NAME, COUNT(*) FROM EMP_39\r

      GROUP BY DEPT_NAME"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT DEPT_NAME, COUNT(*) FROM EMP_39\r

      GROUP BY DEPT_NAME\r

      HAVING COUNT(*) = 0"
    languageId: oracle-sql
  - kind: 1
    value: N)
    languageId: markdown
  - kind: 2
    value: "SELECT * FROM EMP_39 \r

      WHERE ENAME = 'ADAMS'"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT ENAME FROM EMP_39 \r

      WHERE HIREDATE = (\r

      \    SELECT HIREDATE FROM EMP_39 \r

      \    WHERE ENAME = 'ADAMS'\r

      ) AND ENAME <> 'ADAMS'"
    languageId: oracle-sql
  - kind: 1
    value: O)
    languageId: markdown
  - kind: 2
    value: "SELECT DEPT_NAME, MAX(COMM) FROM EMP_39\r

      GROUP BY DEPT_NAME\r

      HAVING MAX(COMM)>0"
    languageId: oracle-sql
  - kind: 1
    value: P)
    languageId: markdown
  - kind: 2
    value: "SELECT DEPT_NAME, ENAME, SAL\r

      FROM EMP_39 E\r

      WHERE SAL = (\r

      \    SELECT MIN(SAL)\r

      \    FROM EMP_39\r

      \    WHERE DEPT_NAME = E.DEPT_NAME\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: DROP TABLE GRADE_39
    languageId: oracle-sql
  - kind: 2
    value: DROP TABLE EMP_39;
    languageId: oracle-sql
