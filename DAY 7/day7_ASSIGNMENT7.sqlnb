cells:
  - kind: 2
    value: "CREATE TABLE EMP_39(\r

      \    EMPNO NUMBER(4) PRIMARY KEY CHECK(EMPNO >=7000 AND EMPNO<=8000),\r

      \    ENAME VARCHAR(10) ,\r

      \    JOB VARCHAR(255),\r

      \    MGR NUMBER(4) REFERENCES EMP_39(EMPNO),\r

      \    HIREDATE DATE,\r

      \    SAL NUMBER(7,2) CHECK (SAL >0),\r

      \    COMM NUMBER(4) DEFAULT 0 CHECK (COMM < 1500) ,\r

      \    DEPT_NAME VARCHAR(255),\r

      \    CITY VARCHAR(255)\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: "CREATE TABLE GRADE_39(\r

      \    GRADE NUMBER(3),\r

      \    MINSAL NUMBER(7,2),\r

      \    MAXSAL NUMBER(7,2)\r

      )"
    languageId: oracle-sql
  - kind: 2
