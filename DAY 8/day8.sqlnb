      INSERT INTO DEPT_39 VALUES (70, 'MARKETING', 'MIAMI');\r

      INSERT INTO DEPT_39 VALUES (80, 'SUPPORT', 'SEATTLE');\r

      INSERT INTO DEPT_39 VALUES (90, 'FINANCE', 'ATLANTA');\r

      INSERT INTO DEPT_39 VALUES (100, 'LEGAL', 'HOUSTON');\r

      INSERT INTO DEPT_39 VALUES (110, 'ADMIN', 'DENVER');\r

      INSERT INTO DEPT_39 VALUES (120, 'SECURITY', 'PHOENIX');\r

