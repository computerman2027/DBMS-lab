cells:
  - kind: 1
    value: "#Assignment 8"
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE DEPT_39\r

      (\r

      \    DEPTNO NUMBER PRIMARY KEY,\r

      \    DNAME VARCHAR(255),\r

      \    LOC VARCHAR(255)\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: "CREATE TABLE EMP_39\r

      (\r

      \    EMPNO NUMBER(5) PRIMARY KEY,\r

      \    ENAME VARCHAR2(255),\r

      \    JOB VARCHAR2(255),\r

      \    HIREDATE DATE,\r

      \    SAL NUMBER(7,2),\r

      \    COMM NUMBER(5),\r

      \    DEPTNO NUMBER REFERENCES DEPT_39(DEPTNO)\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: "INSERT INTO DEPT_39 VALUES (10, 'ACCOUNTING', 'NEW YORK');\r

      INSERT INTO DEPT_39 VALUES (20, 'RESEARCH', 'DALLAS');\r

