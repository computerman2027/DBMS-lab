      INSERT INTO DEPT_39 VALUES (170, 'QUALITY', 'SAN DIEGO');\r

      INSERT INTO DEPT_39 VALUES (180, 'PLANNING', 'PORTLAND');\r

      INSERT INTO DEPT_39 VALUES (190, 'DESIGN', 'COLUMBUS');\r

      INSERT INTO DEPT_39 VALUES (200, 'MANAGEMENT', 'CHARLOTTE');"
    languageId: oracle-sql
