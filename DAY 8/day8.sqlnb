    languageId: oracle-sql
  - kind: 2
    value: SELECT * FROM DEPT_39;
    languageId: oracle-sql
  - kind: 2
    value: SELECT * FROM EMP_39;
    languageId: oracle-sql
  - kind: 2
    value: "SELECT * \r

      FROM EMP_39\r

      WHERE JOB = 'MANAGER' AND SAL > 2500;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT *\r

      FROM EMP_39\r

      WHERE ENAME LIKE 'S%H';"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT ENAME, HIREDATE\r

      FROM EMP_39\r

      WHERE HIREDATE BETWEEN DATE '2021-01-01' AND DATE '2022-12-31'\r

      ORDER BY HIREDATE ASC;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT ENAME, JOB FROM EMP_39\r

      WHERE COMM IS NULL;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT E.ENAME, E.JOB, D.DNAME\r

      FROM EMP_39 E\r

      JOIN DEPT_39 D\r

      ON E.DEPTNO = D.DEPTNO;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT E.ENAME\r

      FROM EMP_39 E\r

      JOIN DEPT_39 D\r

      ON E.DEPTNO = D.DEPTNO\r

      WHERE D.LOC IN ('DALLAS', 'CHICAGO');"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT E.ENAME, E.SAL, D.DNAME\r

      FROM EMP_39 E\r

      JOIN DEPT_39 D\r

      ON E.DEPTNO = D.DEPTNO\r

      WHERE E.SAL BETWEEN 1500 AND 3000;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT \r

      \    SUM(SAL) AS TOTAL_SALARY,\r

      \    AVG(SAL) AS AVERAGE_SALARY,\r

      \    MAX(SAL) AS HIGHEST_SALARY\r

      FROM EMP_39;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT DEPTNO, COUNT(*) AS TOTAL_EMPLOYEES\r

      FROM EMP_39\r

      GROUP BY DEPTNO;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT JOB, SUM(SAL) AS TOTAL_SALARY\r

      FROM EMP_39\r

      GROUP BY JOB\r

      HAVING SUM(SAL) > 5000;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT \r

      \    LOWER(ENAME) AS Name,\r

      \    UPPER(JOB) AS Designation\r

      FROM EMP_39;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT \r

      \    ENAME, \r

      \    SAL, \r

      \    SAL * 12 AS ANNUAL_SAL\r

      FROM EMP_39;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT JOB AS NAME\r

      FROM EMP_39\r

      UNION\r

      SELECT DNAME\r

      FROM DEPT_39;"
    languageId: oracle-sql
  - kind: 2
    value: "UPDATE EMP_39\r

      SET SAL = SAL + 500\r

      WHERE JOB = 'ANALYST';"
    languageId: oracle-sql
  - kind: 2
    value: "DELETE FROM EMP_39\r

      WHERE DEPTNO = 40;"
    languageId: oracle-sql
  - kind: 2
    value: DROP TABLE EMP_39;
    languageId: oracle-sql
  - kind: 2
    value: DROP TABLE DEPT_39;
    languageId: oracle-sql
