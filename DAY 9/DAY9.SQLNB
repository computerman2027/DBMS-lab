cells:
  - kind: 1
    value: "# Assignment day 9"
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE DEPARTMENT_39 (\r

      \    Dept_ID      NUMBER PRIMARY KEY,\r

      \    Dept_Name    VARCHAR2(100) NOT NULL,\r

      \    Budget       NUMBER(12,2),\r

      \    Building     VARCHAR2(100)\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: "CREATE TABLE COURSE_39 (\r

      \    Course_ID    VARCHAR2(10) PRIMARY KEY,\r

      \    Title        VARCHAR2(200) NOT NULL,\r

      \    Dept_ID      NUMBER,\r

      \    Credits      NUMBER(2),\r

      \    CONSTRAINT fk_course_dept\r

      \        FOREIGN KEY (Dept_ID)\r

      \        REFERENCES DEPARTMENT_39(Dept_ID)\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: "CREATE TABLE INSTRUCTOR_39 (\r

      \    ID           NUMBER PRIMARY KEY,\r

      \    Name         VARCHAR2(100) NOT NULL,\r

      \    Dept_ID      NUMBER,\r

      \    Salary       NUMBER(10,2),\r

      \    CONSTRAINT fk_instructor_dept\r

      \        FOREIGN KEY (Dept_ID)\r

      \        REFERENCES DEPARTMENT_39(Dept_ID)\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: "CREATE TABLE STUDENT_39 (\r

      \    ID           NUMBER PRIMARY KEY,\r

      \    Name         VARCHAR2(100) NOT NULL,\r

      \    Dept_ID      NUMBER,\r

      \    Tot_Cred     NUMBER(3),\r

      \    CONSTRAINT fk_student_dept\r

      \        FOREIGN KEY (Dept_ID)\r

      \        REFERENCES DEPARTMENT_39(Dept_ID)\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: "CREATE TABLE TAKES_39 (\r

      \    ID           NUMBER,\r

      \    Course_ID    VARCHAR2(10),\r

      \    Sec_ID       NUMBER,\r

      \    Semester     VARCHAR2(10),\r

      \    Year         NUMBER(4),\r

      \    Grade        VARCHAR2(2),\r

      \    -- CONSTRAINT pk_takes PRIMARY KEY (ID, Course_ID, Sec_ID, Semester,
      Year),\r

      \    CONSTRAINT fk_takes39_student\r

      \        FOREIGN KEY (ID)\r

      \        REFERENCES STUDENT_39(ID),\r

      \    CONSTRAINT fk_takes39_course\r

      \        FOREIGN KEY (Course_ID)\r

      \        REFERENCES COURSE_39(Course_ID)\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: "INSERT ALL\r

      INTO DEPARTMENT_39 VALUES (1, 'Computer Science', 500000, 'Block A')\r

