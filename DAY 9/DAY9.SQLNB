      SELECT * FROM dual;"
    languageId: oracle-sql
  - kind: 1
    value: Q1
    languageId: markdown
  - kind: 2
    value: "SELECT AVG(SALARY)\r

      FROM INSTRUCTOR_39;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT NAME \r

      FROM INSTRUCTOR_39\r

      WHERE SALARY > (\r

      \    SELECT AVG(SALARY)\r

      FROM INSTRUCTOR_39\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Q2
    languageId: markdown
  - kind: 2
    value: "SELECT *\r

      FROM TAKES_39\r

      NATURAL JOIN COURSE_39\r

      NATURAL JOIN DEPARTMENT_39\r

      NATURAL JOIN STUDENT_39;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT *\r

      FROM COURSE_39\r

      NATURAL JOIN DEPARTMENT_39;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT *\r

      FROM COURSE_39\r

      NATURAL JOIN DEPARTMENT_39\r

      WHERE DEPARTMENT_39.DEPT_NAME = 'Computer Science';"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT COURSE_39.COURSE_ID\r

      FROM COURSE_39\r

      NATURAL JOIN DEPARTMENT_39\r

      WHERE DEPARTMENT_39.DEPT_NAME = 'Computer Science';"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT S.Name\r

      FROM STUDENT_39 S\r

      WHERE NOT EXISTS (\r

      \    SELECT C.Course_ID\r

      \    FROM COURSE_39 C\r

      \    JOIN DEPARTMENT_39 D ON C.Dept_ID = D.Dept_ID\r

      \    WHERE D.Dept_Name = 'Computer Science'\r

      \    MINUS\r

      \    SELECT T.Course_ID\r

      \    FROM TAKES_39 T\r

      \    WHERE T.ID = S.ID\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT S.Name\r

      FROM STUDENT_39 S\r

      JOIN TAKES_39 T ON S.ID = T.ID\r

      JOIN COURSE_39 C ON T.Course_ID = C.Course_ID\r

      JOIN DEPARTMENT_39 D ON C.Dept_ID = D.Dept_ID\r

      WHERE D.Dept_Name = 'Computer Science'\r

      GROUP BY S.ID, S.Name\r

      HAVING COUNT(DISTINCT C.Course_ID) = (\r

      \    SELECT COUNT(*)\r

      \    FROM COURSE_39 C\r

      \    JOIN DEPARTMENT_39 D ON C.Dept_ID = D.Dept_ID\r

      \    WHERE D.Dept_Name = 'Computer Science'\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Q3
    languageId: markdown
  - kind: 2
    value: "SELECT Name FROM STUDENT_39\r

      INTERSECT\r

      SELECT Name FROM INSTRUCTOR_39;"
    languageId: oracle-sql
  - kind: 1
    value: Q4
    languageId: markdown
  - kind: 2
    value: "SELECT DISTINCT C.Title\r

      FROM COURSE_39 C\r

      JOIN TAKES_39 T ON C.Course_ID = T.Course_ID\r

      JOIN STUDENT_39 S ON S.ID = T.ID\r

      WHERE S.Name LIKE 'S%n'\r

      \  AND T.Grade = 'A';"
    languageId: oracle-sql
  - kind: 1
    value: Q5
    languageId: markdown
  - kind: 2
    value: "SELECT D.Dept_Name\r

      FROM DEPARTMENT_39 D\r

      JOIN INSTRUCTOR_39 I ON D.Dept_ID = I.Dept_ID\r

      GROUP BY D.Dept_ID, D.Dept_Name\r

      HAVING SUM(I.Salary) > (\r

      \    SELECT AVG(total_salary)\r

      \    FROM (\r

      \        SELECT SUM(Salary) AS total_salary\r

      \        FROM INSTRUCTOR_39\r

      \        GROUP BY Dept_ID\r

      \    )\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: "Q6\r\n"
    languageId: markdown
  - kind: 2
    value: "SELECT D.Dept_Name,\r

      \       NVL(I.Name, 'No Instructor') AS Instructor_Name\r

      FROM DEPARTMENT_39 D\r

      LEFT JOIN INSTRUCTOR_39 I\r

      ON D.Dept_ID = I.Dept_ID\r

      ORDER BY D.Dept_Name;"
    languageId: oracle-sql
  - kind: 1
    value: Q7
    languageId: markdown
  - kind: 2
    value: "SELECT MAX(Salary) AS Third_Highest_Salary\r

      FROM INSTRUCTOR_39\r

      WHERE Salary < (\r

      \    SELECT MAX(Salary)\r

      \    FROM INSTRUCTOR_39\r

      \    WHERE Salary < (\r

      \        SELECT MAX(Salary)\r

      \        FROM INSTRUCTOR_39\r

      \    )\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Q8
    languageId: markdown
  - kind: 2
    value: "SELECT Name,\r

      \       CASE\r

      \           WHEN Tot_Cred > 100 THEN 'Senior'\r

      \           WHEN Tot_Cred BETWEEN 60 AND 100 THEN 'Junior'\r

      \           ELSE 'Sophomore'\r

      \       END AS Category\r

      FROM STUDENT_39;"
    languageId: oracle-sql
  - kind: 1
    value: Q9
    languageId: markdown
  - kind: 2
    value: "SELECT I.ID, I.Name\r

      FROM INSTRUCTOR_39 I\r

      WHERE EXISTS (\r

      \    SELECT 1\r

      \    FROM TAKES_39 T\r

      \    WHERE T.Semester = 'Fall'\r

      \      AND T.Year = 2025\r

      )\r

      AND NOT EXISTS (\r

      \    SELECT 1\r

      \    FROM TAKES_39 T\r

      \    WHERE T.Semester = 'Spring'\r

      \      AND T.Year = 2026\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Q10
    languageId: markdown
  - kind: 2
    value: DROP TABLE TAKES_39;
    languageId: oracle-sql
  - kind: 2
    value: DROP TABLE STUDENT_39;
    languageId: oracle-sql
  - kind: 2
    value: DROP TABLE INSTRUCTOR_39;
    languageId: oracle-sql
  - kind: 2
    value: DROP TABLE COURSE_39;
    languageId: oracle-sql
  - kind: 2
    value: DROP TABLE DEPARTMENT_39;
    languageId: oracle-sql
