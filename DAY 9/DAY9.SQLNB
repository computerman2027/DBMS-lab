      INTO TAKES_39 VALUES (2, 'CS102', 1, 'Spring', 2026, 'A')\r

      INTO TAKES_39 VALUES (3, 'MA101', 1, 'Fall', 2025, 'B')\r

      INTO TAKES_39 VALUES (4, 'PH101', 1, 'Fall', 2025, 'C')\r

