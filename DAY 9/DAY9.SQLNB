  - kind: 2
    value: "INSERT ALL\r

      INTO TAKES_39 VALUES (1, 'CS101', 1, 'Fall', 2025, 'A')\r

      INTO TAKES_39 VALUES (1, 'CS102', 1, 'Fall', 2025, 'A')\r

      INTO TAKES_39 VALUES (1, 'CS103', 1, 'Spring', 2026, 'B')\r

      INTO TAKES_39 VALUES (1, 'CS104', 1, 'Spring', 2026, 'B')\r

