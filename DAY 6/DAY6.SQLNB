cells:
  - kind: 2
    value: "CREATE TABLE ZIPCODES_39(\r

      \    ZIP NUMBER(7) PRIMARY KEY,\r

      \    CITY VARCHAR(255)\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: "CREATE TABLE EMPLOYEES_39\r

      (\r

      \    ENO NUMBER(5) PRIMARY KEY,\r

      \    ENAME VARCHAR(255),\r

      \    ZIP NUMBER(7) REFERENCES ZIPCODES_39(ZIP),\r

      \    HDATE DATE\r

      )"
    languageId: oracle-sql
  - kind: 2
    value: "CREATE TABLE PARTS_39(\r

      \    PNO NUMBER(5) PRIMARY KEY,\r

      \    PNAME VARCHAR(255),\r

      \    QOH NUMBER(5),\r

      \    PRICE NUMBER(7,2),\r

      \    REORDERLEVEL NUMBER(5)\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: "CREATE TABLE CUSTOMERS_39\r

      (\r

      \    CNO NUMBER(5) PRIMARY KEY,\r

      \    CNAME VARCHAR(255),\r

      \    STREET VARCHAR(255),\r

      \    ZIP NUMBER(7) REFERENCES ZIPCODES_39(ZIP),\r

      \    PHONE VARCHAR(10)\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: "CREATE TABLE ORDERS_39\r

      (\r

      \    ONO NUMBER(5) PRIMARY KEY,\r

      \    CNO NUMBER(5) REFERENCES CUSTOMERS_39(CNO),\r

      \    ENO NUMBER(5) REFERENCES EMPLOYEES_39(ENO),\r

      \    RECEIVED NUMBER(1) CHECK (RECEIVED IN (0,1)),\r

      \    SHIPPED NUMBER(1) CHECK (SHIPPED IN (0,1))\r

      );"
    languageId: oracle-sql
  - kind: 2
    value: "CREATE TABLE ODETAILS_39\r

      (\r

      \    ONO NUMBER(5) REFERENCES ORDERS_39(ONO),\r

      \    PNO NUMBER(5) REFERENCES PARTS_39(PNO),\r

      \    QTY NUMBER(5) DEFAULT 0 CHECK (QTY >= 0),\r

      \    PRIMARY KEY(ONO,PNO)\r

      )"
    languageId: oracle-sql
  - kind: 2
