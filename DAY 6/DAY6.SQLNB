  - kind: 2
    value: SELECT * FROM ZIPCODES_39;
    languageId: oracle-sql
  - kind: 2
    value: SELECT * FROM EMPLOYEES_39;
    languageId: oracle-sql
  - kind: 2
    value: SELECT * FROM PARTS_39;
    languageId: oracle-sql
  - kind: 2
    value: SELECT * FROM CUSTOMERS_39;
    languageId: oracle-sql
  - kind: 2
    value: SELECT * FROM ORDERS_39;
    languageId: oracle-sql
  - kind: 2
    value: SELECT * FROM ODETAILS_39;
    languageId: oracle-sql
  - kind: 1
    value: A) Get PNO & PNAME values of parts that are priced less than 20.
    languageId: markdown
  - kind: 2
    value: "SELECT PNO, PNAME\r

      FROM PARTS_39\r

      WHERE PRICE<20;"
    languageId: oracle-sql
  - kind: 1
    value: B) Get PNO values for parts for which orders have been placed
    languageId: markdown
  - kind: 2
    value: "SELECT DISTINCT PNO FROM ODETAILS_39 ORDER BY PNO ASC;\r\n"
    languageId: oracle-sql
  - kind: 1
    value: "C) Get all the details of customers whose names begin with the letter
      “S”. "
    languageId: markdown
  - kind: 2
    value: "SELECT * FROM CUSTOMERS_39\r

      WHERE CNAME LIKE 'S%';"
    languageId: oracle-sql
  - kind: 1
    value: D) Get the ONO & CNAME values for customers whose orders have not yet
      been shipped.
    languageId: markdown
  - kind: 2
    value: "SELECT * FROM ORDERS_39\r

      NATURAL JOIN CUSTOMERS_39;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT * FROM ORDERS_39\r

      NATURAL JOIN CUSTOMERS_39\r

      WHERE SHIPPED = 0;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT ONO, CNAME FROM ORDERS_39\r

      NATURAL JOIN CUSTOMERS_39\r

      WHERE SHIPPED = 0;"
    languageId: oracle-sql
  - kind: 1
    value: "E)Get CNAME & ENAME pairs such the customer with name CNAME has placed
      and ordered \r

      through the employees with name ENAME."
    languageId: markdown
  - kind: 2
    value: "SELECT * FROM ORDERS_39\r

      NATURAL JOIN CUSTOMERS_39\r

      NATURAL JOIN EMPLOYEES_39"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT CNAME,ENAME FROM ORDERS_39\r

      NATURAL JOIN CUSTOMERS_39\r

      NATURAL JOIN EMPLOYEES_39\r

      \r

      -- WRONG"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT C.CNAME, E.ENAME\r

      FROM ORDERS_39 O\r

      JOIN CUSTOMERS_39 C ON O.CNO = C.CNO\r

      JOIN EMPLOYEES_39 E ON O.ENO = E.ENO;"
    languageId: oracle-sql
  - kind: 1
    value: F)Get the name of employees who were hired on the earliest date
    languageId: markdown
  - kind: 2
    value: "SELECT * FROM EMPLOYEES_39\r

      ORDER BY HDATE ASC;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT ENAME\r

      FROM EMPLOYEES_39\r

      WHERE HDATE = (SELECT MIN(HDATE) FROM EMPLOYEES_39);"
    languageId: oracle-sql
  - kind: 1
    value: "G)Retrieve  the  part  number,  part  name  and  price  of  parts  with  \
      price  greater  than  20000  in  an \r

      ascending order of part number."
    languageId: markdown
  - kind: 2
    value: "SELECT PNO, PNAME, PRICE\r

      FROM PARTS_39\r

      WHERE PRICE > 20000\r

      ORDER BY PRICE ASC"
    languageId: oracle-sql
  - kind: 1
    value: "H)For each part, get PNO & PNAME values along with total sales.  \r\n"
    languageId: markdown
  - kind: 2
    value: "SELECT * \r

      FROM ODETAILS_39\r

      NATURAL JOIN PARTS_39;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT PNO, PNAME, (QTY*PRICE) AS TOTAL_SALES\r

      FROM ODETAILS_39\r

      NATURAL JOIN PARTS_39;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT *\r

      FROM PARTS_39 P\r

      JOIN ODETAILS_39 O ON P.PNO = O.PNO;"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT P.PNO, P.PNAME, SUM(O.QTY * P.PRICE) AS TOTAL_SALES\r

      FROM PARTS_39 P\r

      JOIN ODETAILS_39 O ON P.PNO = O.PNO\r

      GROUP BY P.PNO, P.PNAME;"
    languageId: oracle-sql
  - kind: 1
    value: I)Get the total quantity of parts 10601 that has been ordered
    languageId: markdown
  - kind: 2
    value: "SELECT SUM(QTY) AS TOTAL_QUANTITY\r

      FROM ODETAILS_39\r

      WHERE PNO = 10601;"
    languageId: oracle-sql
  - kind: 1
    value: J)Get the ENO values of employees from city “Mumbai”.
    languageId: markdown
  - kind: 2
    value: "SELECT * \r

      FROM EMPLOYEES_39 E\r

      JOIN ZIPCODES_39 Z ON E.ZIP = Z.ZIP\r

      WHERE Z.CITY = 'Mumbai'"
    languageId: oracle-sql
  - kind: 2
    value: DROP TABLE ODETAILS_39;
    languageId: oracle-sql
  - kind: 2
    value: DROP TABLE ORDERS_39;
    languageId: oracle-sql
  - kind: 2
    value: DROP TABLE CUSTOMERS_39;
    languageId: oracle-sql
  - kind: 2
    value: DROP TABLE PARTS_39;
    languageId: oracle-sql
  - kind: 2
    value: DROP TABLE EMPLOYEES_39;
    languageId: oracle-sql
  - kind: 2
    value: DROP TABLE ZIPCODES_39;
    languageId: oracle-sql
